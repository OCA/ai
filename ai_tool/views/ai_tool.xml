<odoo>
    <record model="ir.ui.view" id="ai_tool_form_view">
        <field name="model">ai.tool</field>
        <field name="arch" type="xml">
            <form>
                <header />
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="description" />
                        <field name="kind" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="ai_tool_search_view">
        <field name="model">ai.tool</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
            </search>
        </field>
    </record>

    <record model="ir.ui.view" id="ai_tool_tree_view">
        <field name="model">ai.tool</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
            </tree>
        </field>
    </record>

    <record model="ir.actions.act_window" id="ai_tool_act_window">
        <field name="name">AI Tool</field>
        <field name="res_model">ai.tool</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record model="ir.ui.menu" id="ai_tool_menu">
        <field name="name">AI Tool</field>
        <field name="parent_id" ref="ai_menu_root" />
        <field name="action" ref="ai_tool_act_window" />
        <field name="sequence" eval="16" />
    </record>
</odoo>
