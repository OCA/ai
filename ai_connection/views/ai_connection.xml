<odoo>
    <record model="ir.ui.view" id="ai_connection_form_view">
        <field name="model">ai.connection</field>
        <field name="arch" type="xml">
            <form>
                <header />
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="kind" />
                    </group>
                    <notebook />
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="ai_connection_search_view">
        <field name="model">ai.connection</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
            </search>
        </field>
    </record>

    <record model="ir.ui.view" id="ai_connection_list_view">
        <field name="model">ai.connection</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="kind" />
            </list>
        </field>
    </record>

    <record model="ir.actions.act_window" id="ai_connection_act_window">
        <field name="name">AI Connection</field>
        <field name="res_model">ai.connection</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record model="ir.ui.menu" id="ai_connection_menu">
        <field name="name">AI Connection</field>
        <field name="parent_id" ref="ai_tool.ai_menu_root" />
        <field name="action" ref="ai_connection_act_window" />
        <field name="sequence" eval="16" />
    </record>
</odoo>
