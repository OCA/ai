<odoo>
    <record id="ir_cron_hermes_cleanup_queue" model="ir.cron">
        <field name="name">Hermes: Cleanup old message queue</field>
        <field name="model_id" ref="model_hermes_message_queue" />
        <field name="state">code</field>
        <field name="code">model._cleanup_old_messages()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True" />
    </record>
</odoo>
