<odoo>

    <record model="ir.ui.view" id="mcp_server_log_form_view">
        <field name="model">mcp.server.log</field>
        <field name="arch" type="xml">
            <form>
                <header />
                <sheet>
                    <group>
                        <field name="server_id" />
                        <field name="server_key_id" />
                        <field name="date" />
                    </group>
                    <notebook>
                        <page string="Request">
                            <field name="request" widget="text" />
                        </page>
                        <page string="Response">
                            <field name="response" widget="text" />
                        </page>
                        <page string="Error" invisible="not error">
                            <field name="error" widget="text" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="mcp_server_log_search_view">
        <field name="model">mcp.server.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="server_id" />
                <field name="server_key_id" />
                <field name="date" />
            </search>
        </field>
    </record>

    <record model="ir.ui.view" id="mcp_server_log_tree_view">
        <field name="model">mcp.server.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="server_id" />
                <field name="server_key_id" />
                <field name="date" />
            </tree>
        </field>
    </record>

    <record model="ir.actions.act_window" id="mcp_server_log_server_filter_act_window">
        <field name="name">Mcp Server Log</field>
        <field name="res_model">mcp.server.log</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('server_id', '=', active_id)]</field>
        <field name="context">{}</field>
    </record>

    <record model="ir.actions.act_window" id="mcp_server_log_act_window">
        <field name="name">Mcp Server Log</field>
        <field name="res_model">mcp.server.log</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>


    <record model="ir.ui.menu" id="mcp_server_log_menu">
        <field name="name">MCP Server Log</field>
        <field name="parent_id" ref="ai_tool.ai_menu_root" />
        <field name="action" ref="mcp_server_log_act_window" />
        <field name="sequence" eval="90" />
    </record>

</odoo>
