<odoo>

    <record model="ir.ui.view" id="ai_bridge_form_view_scheduler">
        <field name="model">ai.bridge</field>
        <field name="inherit_id" ref="ai_oca_bridge.ai_bridge_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Scheduler" name="scheduler">
                    <group>
                        <field name="is_scheduled" />
                        <field
                            name="schedule_interval_number"
                            attrs="{'invisible': [('is_scheduled', '=', False)]}"
                        />
                        <field
                            name="schedule_interval_type"
                            attrs="{'invisible': [('is_scheduled', '=', False)]}"
                        />
                        <field
                            name="schedule_nextcall"
                            attrs="{'invisible': [('is_scheduled', '=', False)]}"
                        />
                        <field
                            name="cron_id"
                            readonly="1"
                            attrs="{'invisible': [('is_scheduled', '=', False)]}"
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
